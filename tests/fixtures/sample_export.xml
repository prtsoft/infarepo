  <!-- ================================================================== -->
  <FOLDER DESCRIPTION="Patient data extracts for analytics" GROUP="" NAME="PATIENT_EXTRACT" OWNER="etl_admin" PERMISSIONS="rwx------" SHARED="NOT SHARED">

    <SOURCE BUSINESSNAME="Patient Records" DATABASETYPE="Microsoft SQL Server" DBDNAME="ClinicalDB"
            DESCRIPTION="Patient master" NAME="SRC_PATIENTS" OBJECTVERSION="1" OWNERNAME="dbo">
      <SOURCEFIELD BUSINESSNAME="" DATATYPE="int"      FIELDNUMBER="1" KEYTYPE="PRIMARY KEY" LENGTH="10" NAME="PATIENT_ID"   NULLABLE="NOTNULL" PRECISION="10" SCALE="0"/>
      <SOURCEFIELD BUSINESSNAME="" DATATYPE="nvarchar" FIELDNUMBER="2" KEYTYPE="NOT A KEY"   LENGTH="100" NAME="FULL_NAME"   NULLABLE="NULL"    PRECISION="100" SCALE="0"/>
      <SOURCEFIELD BUSINESSNAME="" DATATYPE="date"     FIELDNUMBER="3" KEYTYPE="NOT A KEY"   LENGTH="10"  NAME="DOB"         NULLABLE="NULL"    PRECISION="10"  SCALE="0"/>
      <SOURCEFIELD BUSINESSNAME="" DATATYPE="nvarchar" FIELDNUMBER="4" KEYTYPE="NOT A KEY"   LENGTH="20"  NAME="MRN"         NULLABLE="NULL"    PRECISION="20"  SCALE="0"/>
      <SOURCEFIELD BUSINESSNAME="" DATATYPE="nvarchar" FIELDNUMBER="5" KEYTYPE="NOT A KEY"   LENGTH="10"  NAME="PAYER_CODE"  NULLABLE="NULL"    PRECISION="10"  SCALE="0"/>
    </SOURCE>

    <!-- Target: Delta Lake on S3 -->
    <TARGET BUSINESSNAME="Patient Delta Table" CONSTRAINT="" DATABASETYPE="DELTA"
            DBDNAME="s3://analytics-lake/patient/" DESCRIPTION="Patient delta extract" NAME="TGT_PATIENT_DELTA" OBJECTVERSION="1" OWNERNAME="">
      <TARGETFIELD BUSINESSNAME="" DATATYPE="int"      FIELDNUMBER="1" KEYTYPE="PRIMARY KEY" NAME="PATIENT_ID"  NULLABLE="NOTNULL" PRECISION="10" SCALE="0"/>
      <TARGETFIELD BUSINESSNAME="" DATATYPE="nvarchar" FIELDNUMBER="2" KEYTYPE="NOT A KEY"   NAME="MRN"          NULLABLE="NULL"    PRECISION="20" SCALE="0"/>
      <TARGETFIELD BUSINESSNAME="" DATATYPE="nvarchar" FIELDNUMBER="3" KEYTYPE="NOT A KEY"   NAME="PAYER_CODE"   NULLABLE="NULL"    PRECISION="10" SCALE="0"/>
      <TARGETFIELD BUSINESSNAME="" DATATYPE="date"     FIELDNUMBER="4" KEYTYPE="NOT A KEY"   NAME="EXTRACT_DATE" NULLABLE="NULL"    PRECISION="10" SCALE="0"/>
    </TARGET>

    <!-- ================================================================
         MAPPING 4: Extract to Delta  →  DATABRICKS
         Score: ~3 (simple)  Platform: DATABRICKS (delta target)
    ================================================================ -->
    <MAPPING DESCRIPTION="Extract patient data to Delta Lake" ISVALID="YES" NAME="M_EXTRACT_PATIENT_DELTA" OBJECTVERSION="1" VERSIONNUMBER="1">

      <INSTANCE DESCRIPTION="" NAME="SRC_PATIENTS"       REUSABLE="NO" TRANSFORMATION="SRC_PATIENTS"      TRANSFORMATIONTYPE="Source Definition" TYPE="SOURCE"/>
      <INSTANCE DESCRIPTION="" NAME="SQ_PATIENTS"        REUSABLE="NO" TRANSFORMATION="SQ_PATIENTS"       TRANSFORMATIONTYPE="Source Qualifier"  TYPE="TRANSFORMATION"/>
      <INSTANCE DESCRIPTION="" NAME="EXP_MASK_PII"       REUSABLE="NO" TRANSFORMATION="EXP_MASK_PII"      TRANSFORMATIONTYPE="Expression"        TYPE="TRANSFORMATION"/>
      <INSTANCE DESCRIPTION="" NAME="TGT_PATIENT_DELTA"  REUSABLE="NO" TRANSFORMATION="TGT_PATIENT_DELTA" TRANSFORMATIONTYPE="Target Definition"  TYPE="TARGET"/>

      <TRANSFORMATION DESCRIPTION="" NAME="SQ_PATIENTS" OBJECTVERSION="1" REUSABLE="NO" TYPE="Source Qualifier" VERSIONNUMBER="1">
        <TRANSFORMFIELD DATATYPE="int"      NAME="PATIENT_ID"  PORTTYPE="OUTPUT" PRECISION="10"  SCALE="0" EXPRESSION="" DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="nvarchar" NAME="FULL_NAME"   PORTTYPE="OUTPUT" PRECISION="100" SCALE="0" EXPRESSION="" DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="date"     NAME="DOB"         PORTTYPE="OUTPUT" PRECISION="10"  SCALE="0" EXPRESSION="" DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="nvarchar" NAME="MRN"         PORTTYPE="OUTPUT" PRECISION="20"  SCALE="0" EXPRESSION="" DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="nvarchar" NAME="PAYER_CODE"  PORTTYPE="OUTPUT" PRECISION="10"  SCALE="0" EXPRESSION="" DEFAULTVALUE=""/>
      </TRANSFORMATION>

      <TRANSFORMATION DESCRIPTION="" NAME="EXP_MASK_PII" OBJECTVERSION="1" REUSABLE="NO" TYPE="Expression" VERSIONNUMBER="1">
        <TRANSFORMFIELD DATATYPE="int"      NAME="PATIENT_ID"   PORTTYPE="INPUT/OUTPUT" PRECISION="10"  SCALE="0" EXPRESSION="PATIENT_ID"                           DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="nvarchar" NAME="MRN"          PORTTYPE="INPUT/OUTPUT" PRECISION="20"  SCALE="0" EXPRESSION="MRN"                                  DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="nvarchar" NAME="PAYER_CODE"   PORTTYPE="INPUT/OUTPUT" PRECISION="10"  SCALE="0" EXPRESSION="PAYER_CODE"                           DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="date"     NAME="EXTRACT_DATE" PORTTYPE="OUTPUT"       PRECISION="10"  SCALE="0" EXPRESSION="TRUNC(SYSDATE)"                       DEFAULTVALUE=""/>
      </TRANSFORMATION>

      <MAPPINGVARIABLE DATATYPE="date/time" DEFAULTVALUE="" DESCRIPTION="" ISEXPRESSIONVARIABLE="NO" ISPARAM="YES" NAME="$$EXTRACT_DT" PRECISION="19" SCALE="0" USERDEFINED="YES"/>

      <CONNECTOR FROMFIELD="PATIENT_ID" FROMINSTANCE="SRC_PATIENTS" FROMINSTANCETYPE="Source Definition" TOFIELD="PATIENT_ID" TOINSTANCE="SQ_PATIENTS" TOINSTANCETYPE="Source Qualifier"/>
      <CONNECTOR FROMFIELD="FULL_NAME"  FROMINSTANCE="SRC_PATIENTS" FROMINSTANCETYPE="Source Definition" TOFIELD="FULL_NAME"  TOINSTANCE="SQ_PATIENTS" TOINSTANCETYPE="Source Qualifier"/>
      <CONNECTOR FROMFIELD="DOB"        FROMINSTANCE="SRC_PATIENTS" FROMINSTANCETYPE="Source Definition" TOFIELD="DOB"        TOINSTANCE="SQ_PATIENTS" TOINSTANCETYPE="Source Qualifier"/>
      <CONNECTOR FROMFIELD="MRN"        FROMINSTANCE="SRC_PATIENTS" FROMINSTANCETYPE="Source Definition" TOFIELD="MRN"        TOINSTANCE="SQ_PATIENTS" TOINSTANCETYPE="Source Qualifier"/>
      <CONNECTOR FROMFIELD="PAYER_CODE" FROMINSTANCE="SRC_PATIENTS" FROMINSTANCETYPE="Source Definition" TOFIELD="PAYER_CODE" TOINSTANCE="SQ_PATIENTS" TOINSTANCETYPE="Source Qualifier"/>
    </MAPPING>

    <WORKFLOW DESCRIPTION="Nightly patient extract" ISENABLED="YES" ISVALID="YES" NAME="WF_PATIENT_EXTRACT_NIGHTLY"
              OBJECTVERSION="1" SERVERNAME="INFA_SERVER_01" VERSIONNUMBER="1">
      <SCHEDULERINFO ENDTIME="00:00:00" SCHEDULETYPE="CUSTOMIZED" STARTTIME="01:00:00"/>
      <TASK DESCRIPTION="" ISENABLED="YES" ISVALID="YES" NAME="s_M_EXTRACT_PATIENT_DELTA" REUSABLE="NO" TYPE="SESSION">
        <SESSION_EXTENSION>
          <MAPPING_REFERENCE MAPPING="M_EXTRACT_PATIENT_DELTA"/>
        </SESSION_EXTENSION>
      </TASK>
      <LINK CONDITION="" FROMTASK="Start" TOTASK="s_M_EXTRACT_PATIENT_DELTA"/>
    </WORKFLOW>

  </FOLDER>

</REPOSITORY>
</POWERMART>
