        <TRANSFORMFIELD DATATYPE="nvarchar" NAME="CUSTOMER_ID" PORTTYPE="INPUT/OUTPUT" PRECISION="50" SCALE="0" EXPRESSION="CUSTOMER_ID" DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="decimal"  NAME="ORDER_AMT"   PORTTYPE="INPUT/OUTPUT" PRECISION="18" SCALE="2" EXPRESSION="ORDER_AMT" DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="nvarchar" NAME="STATUS"      PORTTYPE="INPUT/OUTPUT" PRECISION="20" SCALE="0" EXPRESSION="STATUS"    DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="datetime" NAME="LOAD_TS"     PORTTYPE="INPUT/OUTPUT" PRECISION="23" SCALE="3" EXPRESSION="LOAD_TS"   DEFAULTVALUE=""/>
        <TABLEATTRIBUTE NAME="Filter Condition" VALUE="STATUS != 'CANCELLED'"/>
      </TRANSFORMATION>

      <CONNECTOR FROMFIELD="ORDER_ID"    FROMINSTANCE="SRC_ORDERS"       FROMINSTANCETYPE="Source Definition"  TOFIELD="ORDER_ID"    TOINSTANCE="SQ_ORDERS"       TOINSTANCETYPE="Source Qualifier"/>
      <CONNECTOR FROMFIELD="CUSTOMER_ID" FROMINSTANCE="SRC_ORDERS"       FROMINSTANCETYPE="Source Definition"  TOFIELD="CUSTOMER_ID" TOINSTANCE="SQ_ORDERS"       TOINSTANCETYPE="Source Qualifier"/>
      <CONNECTOR FROMFIELD="ORDER_AMT"   FROMINSTANCE="SRC_ORDERS"       FROMINSTANCETYPE="Source Definition"  TOFIELD="ORDER_AMT"   TOINSTANCE="SQ_ORDERS"       TOINSTANCETYPE="Source Qualifier"/>
      <CONNECTOR FROMFIELD="ORDER_DATE"  FROMINSTANCE="SRC_ORDERS"       FROMINSTANCETYPE="Source Definition"  TOFIELD="ORDER_DATE"  TOINSTANCE="SQ_ORDERS"       TOINSTANCETYPE="Source Qualifier"/>
      <CONNECTOR FROMFIELD="STATUS"      FROMINSTANCE="SRC_ORDERS"       FROMINSTANCETYPE="Source Definition"  TOFIELD="STATUS"      TOINSTANCE="SQ_ORDERS"       TOINSTANCETYPE="Source Qualifier"/>
