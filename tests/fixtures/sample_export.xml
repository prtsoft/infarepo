      <TRANSFORMATION DESCRIPTION="" NAME="EXP_DERIVE" OBJECTVERSION="1" REUSABLE="NO" TYPE="Expression" VERSIONNUMBER="1">
        <TRANSFORMFIELD DATATYPE="int"      NAME="ORDER_ID"    PORTTYPE="INPUT/OUTPUT" PRECISION="10" SCALE="0" EXPRESSION="ORDER_ID"           DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="nvarchar" NAME="CUSTOMER_ID" PORTTYPE="INPUT/OUTPUT" PRECISION="50" SCALE="0" EXPRESSION="CUSTOMER_ID"         DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="decimal"  NAME="ORDER_AMT"   PORTTYPE="INPUT/OUTPUT" PRECISION="18" SCALE="2" EXPRESSION="ORDER_AMT"           DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="nvarchar" NAME="STATUS"      PORTTYPE="INPUT/OUTPUT" PRECISION="20" SCALE="0" EXPRESSION="STATUS"              DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="datetime" NAME="LOAD_TS"     PORTTYPE="OUTPUT"       PRECISION="23" SCALE="3" EXPRESSION="SYSDATE"             DEFAULTVALUE=""/>
      </TRANSFORMATION>

      <TRANSFORMATION DESCRIPTION="" NAME="FIL_STATUS" OBJECTVERSION="1" REUSABLE="NO" TYPE="Filter" VERSIONNUMBER="1">
