      <CONNECTOR FROMFIELD="ORDER_AMT"   FROMINSTANCE="EXP_DERIVE"       FROMINSTANCETYPE="Expression"         TOFIELD="ORDER_AMT"   TOINSTANCE="FIL_STATUS"      TOINSTANCETYPE="Filter"/>
