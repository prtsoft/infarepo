      <CONNECTOR FROMFIELD="LOAD_TS"     FROMINSTANCE="EXP_DERIVE"       FROMINSTANCETYPE="Expression"         TOFIELD="LOAD_TS"     TOINSTANCE="FIL_STATUS"      TOINSTANCETYPE="Filter"/>
      <CONNECTOR FROMFIELD="ORDER_ID"    FROMINSTANCE="FIL_STATUS"       FROMINSTANCETYPE="Filter"             TOFIELD="ORDER_ID"    TOINSTANCE="TGT_FACT_ORDERS" TOINSTANCETYPE="Target Definition"/>
      <CONNECTOR FROMFIELD="CUSTOMER_ID" FROMINSTANCE="FIL_STATUS"       FROMINSTANCETYPE="Filter"             TOFIELD="CUSTOMER_ID" TOINSTANCE="TGT_FACT_ORDERS" TOINSTANCETYPE="Target Definition"/>
      <CONNECTOR FROMFIELD="ORDER_AMT"   FROMINSTANCE="FIL_STATUS"       FROMINSTANCETYPE="Filter"             TOFIELD="ORDER_AMT"   TOINSTANCE="TGT_FACT_ORDERS" TOINSTANCETYPE="Target Definition"/>
      <CONNECTOR FROMFIELD="LOAD_TS"     FROMINSTANCE="FIL_STATUS"       FROMINSTANCETYPE="Filter"             TOFIELD="LOAD_TS"     TOINSTANCE="TGT_FACT_ORDERS" TOINSTANCETYPE="Target Definition"/>

      <MAPPINGVARIABLE DATATYPE="date/time" DEFAULTVALUE="" DESCRIPTION="" ISEXPRESSIONVARIABLE="NO" ISPARAM="YES" NAME="$$START_DATE" PRECISION="19" SCALE="0" USERDEFINED="YES"/>
