      <CONNECTOR FROMFIELD="CUSTOMER_ID" FROMINSTANCE="SQ_ORDERS"        FROMINSTANCETYPE="Source Qualifier"   TOFIELD="CUSTOMER_ID" TOINSTANCE="EXP_DERIVE"      TOINSTANCETYPE="Expression"/>
      <CONNECTOR FROMFIELD="ORDER_AMT"   FROMINSTANCE="SQ_ORDERS"        FROMINSTANCETYPE="Source Qualifier"   TOFIELD="ORDER_AMT"   TOINSTANCE="EXP_DERIVE"      TOINSTANCETYPE="Expression"/>
      <CONNECTOR FROMFIELD="STATUS"      FROMINSTANCE="SQ_ORDERS"        FROMINSTANCETYPE="Source Qualifier"   TOFIELD="STATUS"      TOINSTANCE="EXP_DERIVE"      TOINSTANCETYPE="Expression"/>
      <CONNECTOR FROMFIELD="ORDER_ID"    FROMINSTANCE="EXP_DERIVE"       FROMINSTANCETYPE="Expression"         TOFIELD="ORDER_ID"    TOINSTANCE="FIL_STATUS"      TOINSTANCETYPE="Filter"/>
