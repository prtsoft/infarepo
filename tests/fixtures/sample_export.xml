    <!-- ================================================================
         MAPPING 2: Moderate — Joiner + Lookup + Router + SQL override
         Score: ~6 (moderate)  Platform: GLUE
    ================================================================ -->
    <MAPPING DESCRIPTION="Enrich orders with customer and product data" ISVALID="YES" NAME="M_ENRICH_ORDERS" OBJECTVERSION="1" VERSIONNUMBER="1">

      <INSTANCE DESCRIPTION="" NAME="SRC_ORDERS"       REUSABLE="NO" TRANSFORMATION="SRC_ORDERS"    TRANSFORMATIONTYPE="Source Definition" TYPE="SOURCE"/>
      <INSTANCE DESCRIPTION="" NAME="SRC_PRODUCT_FILE" REUSABLE="NO" TRANSFORMATION="SRC_PRODUCT_FILE" TRANSFORMATIONTYPE="Source Definition" TYPE="SOURCE"/>
      <INSTANCE DESCRIPTION="" NAME="SQ_ORDERS_ENR"    REUSABLE="NO" TRANSFORMATION="SQ_ORDERS_ENR"  TRANSFORMATIONTYPE="Source Qualifier"  TYPE="TRANSFORMATION"/>
      <INSTANCE DESCRIPTION="" NAME="SQ_PRODUCT"       REUSABLE="NO" TRANSFORMATION="SQ_PRODUCT"     TRANSFORMATIONTYPE="Source Qualifier"  TYPE="TRANSFORMATION"/>
      <INSTANCE DESCRIPTION="" NAME="JNR_ORD_PROD"     REUSABLE="NO" TRANSFORMATION="JNR_ORD_PROD"   TRANSFORMATIONTYPE="Joiner"            TYPE="TRANSFORMATION"/>
      <INSTANCE DESCRIPTION="" NAME="LKP_CUSTOMER"     REUSABLE="NO" TRANSFORMATION="LKP_CUSTOMER"   TRANSFORMATIONTYPE="Lookup Procedure"  TYPE="TRANSFORMATION"/>
      <INSTANCE DESCRIPTION="" NAME="RTR_REGION"       REUSABLE="NO" TRANSFORMATION="RTR_REGION"     TRANSFORMATIONTYPE="Router"            TYPE="TRANSFORMATION"/>
      <INSTANCE DESCRIPTION="" NAME="TGT_FACT_ORDERS"  REUSABLE="NO" TRANSFORMATION="TGT_FACT_ORDERS" TRANSFORMATIONTYPE="Target Definition" TYPE="TARGET"/>

      <TRANSFORMATION DESCRIPTION="" NAME="SQ_ORDERS_ENR" OBJECTVERSION="1" REUSABLE="NO" TYPE="Source Qualifier" VERSIONNUMBER="1">
        <TRANSFORMFIELD DATATYPE="int"      NAME="ORDER_ID"    PORTTYPE="OUTPUT" PRECISION="10" SCALE="0" EXPRESSION="" DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="nvarchar" NAME="CUSTOMER_ID" PORTTYPE="OUTPUT" PRECISION="50" SCALE="0" EXPRESSION="" DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="decimal"  NAME="ORDER_AMT"   PORTTYPE="OUTPUT" PRECISION="18" SCALE="2" EXPRESSION="" DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="nvarchar" NAME="PROD_CODE"   PORTTYPE="OUTPUT" PRECISION="10" SCALE="0" EXPRESSION="" DEFAULTVALUE=""/>
        <TABLEATTRIBUTE NAME="Sql Query" VALUE="SELECT o.ORDER_ID, o.CUSTOMER_ID, o.ORDER_AMT, od.PROD_CODE FROM dbo.ORDERS o INNER JOIN dbo.ORDER_DETAIL od ON o.ORDER_ID = od.ORDER_ID WHERE o.ORDER_DATE &gt;= DATEADD(day, -30, GETDATE()) AND o.STATUS NOT IN ('CANCELLED', 'RETURNED')"/>
      </TRANSFORMATION>

      <TRANSFORMATION DESCRIPTION="" NAME="SQ_PRODUCT" OBJECTVERSION="1" REUSABLE="NO" TYPE="Source Qualifier" VERSIONNUMBER="1">
        <TRANSFORMFIELD DATATYPE="string"  NAME="PROD_CODE"  PORTTYPE="OUTPUT" PRECISION="10" SCALE="0" EXPRESSION="" DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="string"  NAME="PROD_DESC"  PORTTYPE="OUTPUT" PRECISION="50" SCALE="0" EXPRESSION="" DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="decimal" NAME="UNIT_PRICE" PORTTYPE="OUTPUT" PRECISION="10" SCALE="4" EXPRESSION="" DEFAULTVALUE=""/>
      </TRANSFORMATION>

      <TRANSFORMATION DESCRIPTION="" NAME="JNR_ORD_PROD" OBJECTVERSION="1" REUSABLE="NO" TYPE="Joiner" VERSIONNUMBER="1">
        <TRANSFORMFIELD DATATYPE="int"      NAME="ORDER_ID"    PORTTYPE="OUTPUT"       PRECISION="10" SCALE="0" EXPRESSION="" DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="nvarchar" NAME="CUSTOMER_ID" PORTTYPE="OUTPUT"       PRECISION="50" SCALE="0" EXPRESSION="" DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="decimal"  NAME="ORDER_AMT"   PORTTYPE="OUTPUT"       PRECISION="18" SCALE="2" EXPRESSION="" DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="nvarchar" NAME="PROD_CODE"   PORTTYPE="DETAIL INPUT" PRECISION="10" SCALE="0" EXPRESSION="" DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="string"   NAME="PROD_DESC"   PORTTYPE="OUTPUT"       PRECISION="50" SCALE="0" EXPRESSION="" DEFAULTVALUE=""/>
        <TABLEATTRIBUTE NAME="Join Condition"  VALUE="PROD_CODE = PROD_CODE"/>
        <TABLEATTRIBUTE NAME="Join Type"       VALUE="Normal Join"/>
        <TABLEATTRIBUTE NAME="Master Source"   VALUE="Detail"/>
      </TRANSFORMATION>

      <TRANSFORMATION DESCRIPTION="" NAME="LKP_CUSTOMER" OBJECTVERSION="1" REUSABLE="NO" TYPE="Lookup Procedure" VERSIONNUMBER="1">
        <TRANSFORMFIELD DATATYPE="nvarchar" NAME="CUSTOMER_ID"    PORTTYPE="INPUT"  PRECISION="50"  SCALE="0" EXPRESSION="" DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="nvarchar" NAME="LKP_CUST_NAME"  PORTTYPE="OUTPUT" PRECISION="100" SCALE="0" EXPRESSION="" DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="nvarchar" NAME="LKP_REGION"     PORTTYPE="OUTPUT" PRECISION="20"  SCALE="0" EXPRESSION="" DEFAULTVALUE=""/>
        <TABLEATTRIBUTE NAME="Lookup Condition"  VALUE="CUSTOMER_ID = CUSTOMER_ID"/>
        <TABLEATTRIBUTE NAME="Lookup Table Name" VALUE="SRC_CUSTOMER"/>
        <TABLEATTRIBUTE NAME="Lookup Policy On Multiple Match" VALUE="Use First Value"/>
      </TRANSFORMATION>

      <TRANSFORMATION DESCRIPTION="" NAME="RTR_REGION" OBJECTVERSION="1" REUSABLE="NO" TYPE="Router" VERSIONNUMBER="1">
        <TRANSFORMFIELD DATATYPE="int"      NAME="ORDER_ID"    PORTTYPE="INPUT" PRECISION="10"  SCALE="0" EXPRESSION="" DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="nvarchar" NAME="CUSTOMER_ID" PORTTYPE="INPUT" PRECISION="50"  SCALE="0" EXPRESSION="" DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="decimal"  NAME="ORDER_AMT"   PORTTYPE="INPUT" PRECISION="18"  SCALE="2" EXPRESSION="" DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="nvarchar" NAME="LKP_REGION"  PORTTYPE="INPUT" PRECISION="20"  SCALE="0" EXPRESSION="" DEFAULTVALUE=""/>
        <GROUPATTR CONDITION="LKP_REGION = 'NORTH'" NAME="GRP_NORTH"/>
        <GROUPATTR CONDITION="LKP_REGION = 'SOUTH'" NAME="GRP_SOUTH"/>
        <GROUPATTR CONDITION="" NAME="DEFAULT1"/>
      </TRANSFORMATION>

      <MAPPINGVARIABLE DATATYPE="date/time" DEFAULTVALUE="" DESCRIPTION="" ISEXPRESSIONVARIABLE="NO" ISPARAM="YES" NAME="$$LOAD_DATE"  PRECISION="19" SCALE="0" USERDEFINED="YES"/>
      <MAPPINGVARIABLE DATATYPE="nvarchar"  DEFAULTVALUE="" DESCRIPTION="" ISEXPRESSIONVARIABLE="NO" ISPARAM="YES" NAME="$$ENV"        PRECISION="10" SCALE="0" USERDEFINED="YES"/>
      <MAPPINGVARIABLE DATATYPE="integer"   DEFAULTVALUE="0" DESCRIPTION="" ISEXPRESSIONVARIABLE="NO" ISPARAM="NO" NAME="$$ROW_COUNT" PRECISION="10" SCALE="0" USERDEFINED="YES"/>
    </MAPPING>

    <!-- ================================================================
         MAPPING 3: Complex — Stored Procedure + high score → REVIEW
         Score: ~8 (complex)  Platform: REVIEW
    ================================================================ -->
    <MAPPING DESCRIPTION="Process orders via stored procedure" ISVALID="YES" NAME="M_PROC_ORDERS_SP" OBJECTVERSION="1" VERSIONNUMBER="1">

      <INSTANCE DESCRIPTION="" NAME="SRC_ORDERS"    REUSABLE="NO" TRANSFORMATION="SRC_ORDERS"     TRANSFORMATIONTYPE="Source Definition"  TYPE="SOURCE"/>
      <INSTANCE DESCRIPTION="" NAME="SQ_SP_ORDERS"  REUSABLE="NO" TRANSFORMATION="SQ_SP_ORDERS"   TRANSFORMATIONTYPE="Source Qualifier"   TYPE="TRANSFORMATION"/>
      <INSTANCE DESCRIPTION="" NAME="SP_CALC_TAX"   REUSABLE="NO" TRANSFORMATION="SP_CALC_TAX"    TRANSFORMATIONTYPE="Stored Procedure"   TYPE="TRANSFORMATION"/>
      <INSTANCE DESCRIPTION="" NAME="AGG_SUMMARY"   REUSABLE="NO" TRANSFORMATION="AGG_SUMMARY"    TRANSFORMATIONTYPE="Aggregator"         TYPE="TRANSFORMATION"/>
      <INSTANCE DESCRIPTION="" NAME="TGT_FACT_ORDERS" REUSABLE="NO" TRANSFORMATION="TGT_FACT_ORDERS" TRANSFORMATIONTYPE="Target Definition" TYPE="TARGET"/>

      <TRANSFORMATION DESCRIPTION="" NAME="SQ_SP_ORDERS" OBJECTVERSION="1" REUSABLE="NO" TYPE="Source Qualifier" VERSIONNUMBER="1">
        <TRANSFORMFIELD DATATYPE="int"     NAME="ORDER_ID"   PORTTYPE="OUTPUT" PRECISION="10" SCALE="0" EXPRESSION="" DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="decimal" NAME="ORDER_AMT"  PORTTYPE="OUTPUT" PRECISION="18" SCALE="2" EXPRESSION="" DEFAULTVALUE=""/>
        <TABLEATTRIBUTE NAME="Sql Query" VALUE="SELECT ORDER_ID, CUSTOMER_ID, ORDER_AMT, STATUS, REGION, PROD_CODE, NOTES FROM dbo.ORDERS WHERE STATUS = 'APPROVED' AND REGION IS NOT NULL AND ORDER_DATE BETWEEN $$START_DATE AND $$END_DATE AND EXISTS (SELECT 1 FROM dbo.CUSTOMERS C WHERE C.CUSTOMER_ID = ORDERS.CUSTOMER_ID AND C.ACTIVE_FLAG = 1)"/>
      </TRANSFORMATION>

      <TRANSFORMATION DESCRIPTION="" NAME="SP_CALC_TAX" OBJECTVERSION="1" REUSABLE="NO" TYPE="Stored Procedure" VERSIONNUMBER="1">
        <TRANSFORMFIELD DATATYPE="decimal" NAME="IN_ORDER_AMT"  PORTTYPE="INPUT"  PRECISION="18" SCALE="2" EXPRESSION="" DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="nvarchar" NAME="IN_REGION"    PORTTYPE="INPUT"  PRECISION="20" SCALE="0" EXPRESSION="" DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="decimal" NAME="OUT_TAX_AMT"   PORTTYPE="OUTPUT" PRECISION="18" SCALE="2" EXPRESSION="" DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="decimal" NAME="OUT_TOTAL_AMT" PORTTYPE="OUTPUT" PRECISION="18" SCALE="2" EXPRESSION="" DEFAULTVALUE=""/>
        <TABLEATTRIBUTE NAME="Stored Procedure Name" VALUE="dbo.usp_CalculateTax"/>
        <TABLEATTRIBUTE NAME="Stored Procedure Type" VALUE="Normal"/>
      </TRANSFORMATION>

      <TRANSFORMATION DESCRIPTION="" NAME="AGG_SUMMARY" OBJECTVERSION="1" REUSABLE="NO" TYPE="Aggregator" VERSIONNUMBER="1">
        <TRANSFORMFIELD DATATYPE="int"     NAME="ORDER_ID"   PORTTYPE="INPUT/OUTPUT"  PRECISION="10" SCALE="0" EXPRESSION="ORDER_ID"               DEFAULTVALUE=""/>
        <TRANSFORMFIELD DATATYPE="decimal" NAME="TOTAL_AMT"  PORTTYPE="OUTPUT"        PRECISION="18" SCALE="2" EXPRESSION="SUM(OUT_TOTAL_AMT)"      DEFAULTVALUE=""/>
        <TABLEATTRIBUTE NAME="Cache Directory" VALUE="$PMCacheDir"/>
        <TABLEATTRIBUTE NAME="Cache Size"      VALUE="Auto"/>
      </TRANSFORMATION>

      <MAPPINGVARIABLE DATATYPE="date/time" DEFAULTVALUE="" DESCRIPTION="" ISEXPRESSIONVARIABLE="NO" ISPARAM="YES" NAME="$$START_DATE" PRECISION="19" SCALE="0" USERDEFINED="YES"/>
      <MAPPINGVARIABLE DATATYPE="date/time" DEFAULTVALUE="" DESCRIPTION="" ISEXPRESSIONVARIABLE="NO" ISPARAM="YES" NAME="$$END_DATE"   PRECISION="19" SCALE="0" USERDEFINED="YES"/>
    </MAPPING>

    <!-- ================================================================
         WORKFLOW 1: Runs all three mappings sequentially
    ================================================================ -->
    <WORKFLOW DESCRIPTION="Daily sales mart load" ISENABLED="YES" ISVALID="YES" NAME="WF_SALES_MART_DAILY"
              OBJECTVERSION="1" SERVERNAME="INFA_SERVER_01" VERSIONNUMBER="1">
      <SCHEDULERINFO ENDTIME="00:00:00" SCHEDULETYPE="CUSTOMIZED" STARTTIME="02:00:00"
                     RERUN_TYPE="NONE" STARTDAY="0" LASTDAY="NO"/>

      <TASK DESCRIPTION="" ISENABLED="YES" ISVALID="YES" NAME="s_M_LOAD_FACT_ORDERS"   REUSABLE="NO" TYPE="SESSION">
        <SESSION_EXTENSION>
          <MAPPING_REFERENCE MAPPING="M_LOAD_FACT_ORDERS"/>
        </SESSION_EXTENSION>
      </TASK>
      <TASK DESCRIPTION="" ISENABLED="YES" ISVALID="YES" NAME="s_M_ENRICH_ORDERS"     REUSABLE="NO" TYPE="SESSION">
        <SESSION_EXTENSION>
          <MAPPING_REFERENCE MAPPING="M_ENRICH_ORDERS"/>
        </SESSION_EXTENSION>
      </TASK>
      <TASK DESCRIPTION="" ISENABLED="YES" ISVALID="YES" NAME="s_M_PROC_ORDERS_SP"    REUSABLE="NO" TYPE="SESSION">
        <SESSION_EXTENSION>
          <MAPPING_REFERENCE MAPPING="M_PROC_ORDERS_SP"/>
        </SESSION_EXTENSION>
      </TASK>
      <TASK DESCRIPTION="" ISENABLED="YES" ISVALID="YES" NAME="cmd_notify"            REUSABLE="NO" TYPE="COMMAND"/>

      <LINK CONDITION="" FROMTASK="Start"                   TOTASK="s_M_LOAD_FACT_ORDERS"/>
      <LINK CONDITION="" FROMTASK="s_M_LOAD_FACT_ORDERS"   TOTASK="s_M_ENRICH_ORDERS"/>
      <LINK CONDITION="" FROMTASK="s_M_ENRICH_ORDERS"       TOTASK="s_M_PROC_ORDERS_SP"/>
      <LINK CONDITION="" FROMTASK="s_M_PROC_ORDERS_SP"      TOTASK="cmd_notify"/>
    </WORKFLOW>

  </FOLDER>

