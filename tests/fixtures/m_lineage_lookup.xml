<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE POWERMART SYSTEM "powrmart.dtd">
<!--
  Lineage test fixture: connected lookup + unconnected lookup in expression.

  Mapping: m_lineage_lookup
    SRC_ORDERS ──> SQ_ORDERS ──> EXP_ENRICH ──> TGT_ORDERS
                                     ^
                                LKP_REGION (connected lookup)

  Connected lookup: REGION comes from LKP_REGION.OUT_REGION (return port),
    fed by EXP_ENRICH.CUSTOMER_ID input → LKP_REGION.IN_CUST_ID.

  Unconnected lookup: TAX_CODE uses :LKP.LKP_TAX_CODE(COUNTRY_CODE) in expression.

  Target fields:
    ORDER_ID   → straight move from SRC_ORDERS.ORDER_ID
    REGION     → connected lookup LKP_REGION on SRC_REGION, return OUT_REGION
    TAX_CODE   → expression with unconnected :LKP.LKP_TAX_CODE(COUNTRY_CODE)
    LOAD_TS    → SYSDATE (no source)
-->
<POWERMART CREATION_DATE="01/01/2024 00:00:00" REPOSITORY_VERSION="186.97">
<REPOSITORY NAME="TEST_REPO" VERSION="186" CODEPAGE="UTF-8" DATABASETYPE="Oracle">
<FOLDER NAME="TEST_FOLDER" DESCRIPTION="" GROUP="" OWNER="etl_admin" PERMISSIONS="rwx------" SHARED="NOTSHARED">

  <SOURCE DATABASETYPE="Oracle" DBDNAME="ODS" DESCRIPTION="" NAME="SRC_ORDERS" OWNERNAME="dbo">
    <SOURCEFIELD DATATYPE="integer" FIELDNUMBER="1" KEYTYPE="PRIMARY KEY" NAME="ORDER_ID"    NULLABLE="NOTNULL" PRECISION="10" SCALE="0"/>
    <SOURCEFIELD DATATYPE="nvarchar" FIELDNUMBER="2" KEYTYPE="NOT A KEY"  NAME="CUSTOMER_ID" NULLABLE="NULL"    PRECISION="50" SCALE="0"/>
    <SOURCEFIELD DATATYPE="nvarchar" FIELDNUMBER="3" KEYTYPE="NOT A KEY"  NAME="COUNTRY_CODE" NULLABLE="NULL"   PRECISION="5"  SCALE="0"/>
  </SOURCE>

  <SOURCE DATABASETYPE="Oracle" DBDNAME="ODS" DESCRIPTION="Region lookup table" NAME="SRC_REGION" OWNERNAME="dbo">
    <SOURCEFIELD DATATYPE="nvarchar" FIELDNUMBER="1" KEYTYPE="PRIMARY KEY" NAME="CUSTOMER_ID" NULLABLE="NOTNULL" PRECISION="50" SCALE="0"/>
    <SOURCEFIELD DATATYPE="nvarchar" FIELDNUMBER="2" KEYTYPE="NOT A KEY"   NAME="REGION"      NULLABLE="NULL"    PRECISION="20" SCALE="0"/>
  </SOURCE>

  <TARGET DATABASETYPE="Oracle" DBDNAME="DWH" DESCRIPTION="" NAME="TGT_ORDERS" OWNERNAME="dbo">
    <TARGETFIELD DATATYPE="integer"  FIELDNUMBER="1" KEYTYPE="PRIMARY KEY" NAME="ORDER_ID"   NULLABLE="NOTNULL" PRECISION="10" SCALE="0"/>
    <TARGETFIELD DATATYPE="nvarchar" FIELDNUMBER="2" KEYTYPE="NOT A KEY"   NAME="REGION"     NULLABLE="NULL"    PRECISION="20" SCALE="0"/>
    <TARGETFIELD DATATYPE="nvarchar" FIELDNUMBER="3" KEYTYPE="NOT A KEY"   NAME="TAX_CODE"   NULLABLE="NULL"    PRECISION="10" SCALE="0"/>
    <TARGETFIELD DATATYPE="datetime" FIELDNUMBER="4" KEYTYPE="NOT A KEY"   NAME="LOAD_TS"    NULLABLE="NULL"    PRECISION="23" SCALE="3"/>
  </TARGET>

  <MAPPING DESCRIPTION="Lineage lookup test mapping" ISVALID="YES" NAME="m_lineage_lookup">

    <INSTANCE NAME="SRC_ORDERS"   TRANSFORMATION="SRC_ORDERS"   TRANSFORMATIONTYPE="Source Definition" TYPE="SOURCE"/>
    <INSTANCE NAME="SQ_ORDERS"    TRANSFORMATION="SQ_ORDERS"    TRANSFORMATIONTYPE="Source Qualifier"  TYPE="TRANSFORMATION"/>
    <INSTANCE NAME="LKP_REGION"   TRANSFORMATION="LKP_REGION"   TRANSFORMATIONTYPE="Lookup Procedure"  TYPE="TRANSFORMATION"/>
    <INSTANCE NAME="LKP_TAX_CODE" TRANSFORMATION="LKP_TAX_CODE" TRANSFORMATIONTYPE="Lookup Procedure"  TYPE="TRANSFORMATION"/>
    <INSTANCE NAME="EXP_ENRICH"   TRANSFORMATION="EXP_ENRICH"   TRANSFORMATIONTYPE="Expression"        TYPE="TRANSFORMATION"/>
    <INSTANCE NAME="TGT_ORDERS"   TRANSFORMATION="TGT_ORDERS"   TRANSFORMATIONTYPE="Target Definition" TYPE="TARGET"/>

    <!-- Source Qualifier: OUTPUT-only ports (tests SQ OUTPUT fallback path) -->
    <TRANSFORMATION NAME="SQ_ORDERS" TYPE="Source Qualifier">
      <TRANSFORMFIELD NAME="ORDER_ID"    PORTTYPE="OUTPUT" DATATYPE="integer"  PRECISION="10" SCALE="0" EXPRESSION="" DEFAULTVALUE=""/>
      <TRANSFORMFIELD NAME="CUSTOMER_ID" PORTTYPE="OUTPUT" DATATYPE="nvarchar" PRECISION="50" SCALE="0" EXPRESSION="" DEFAULTVALUE=""/>
      <TRANSFORMFIELD NAME="COUNTRY_CODE" PORTTYPE="OUTPUT" DATATYPE="nvarchar" PRECISION="5" SCALE="0" EXPRESSION="" DEFAULTVALUE=""/>
      <TABLEATTRIBUTE NAME="Sql Query"    VALUE=""/>
      <TABLEATTRIBUTE NAME="Source Filter" VALUE=""/>
    </TRANSFORMATION>

    <!-- Connected lookup on SRC_REGION -->
    <TRANSFORMATION NAME="LKP_REGION" TYPE="Lookup Procedure">
      <TRANSFORMFIELD NAME="IN_CUST_ID"  PORTTYPE="INPUT"  DATATYPE="nvarchar" PRECISION="50" SCALE="0" EXPRESSION="" DEFAULTVALUE=""/>
      <TRANSFORMFIELD NAME="OUT_REGION"  PORTTYPE="OUTPUT" DATATYPE="nvarchar" PRECISION="20" SCALE="0" EXPRESSION="" DEFAULTVALUE=""/>
      <TABLEATTRIBUTE NAME="Lookup Condition"   VALUE="IN_CUST_ID = CUSTOMER_ID"/>
      <TABLEATTRIBUTE NAME="Lookup Table Name"  VALUE="SRC_REGION"/>
    </TRANSFORMATION>

    <!-- Unconnected lookup — only referenced via :LKP. in expression, never wired by connector -->
    <TRANSFORMATION NAME="LKP_TAX_CODE" TYPE="Lookup Procedure">
      <TRANSFORMFIELD NAME="IN_COUNTRY"  PORTTYPE="INPUT"  DATATYPE="nvarchar" PRECISION="5"  SCALE="0" EXPRESSION="" DEFAULTVALUE=""/>
      <TRANSFORMFIELD NAME="OUT_TAX"     PORTTYPE="OUTPUT" DATATYPE="nvarchar" PRECISION="10" SCALE="0" EXPRESSION="" DEFAULTVALUE=""/>
      <TABLEATTRIBUTE NAME="Lookup Condition"   VALUE="IN_COUNTRY = COUNTRY_CODE"/>
      <TABLEATTRIBUTE NAME="Lookup Table Name"  VALUE="TAX_CODES"/>
    </TRANSFORMATION>

    <!-- Expression transformation -->
    <TRANSFORMATION NAME="EXP_ENRICH" TYPE="Expression">
      <TRANSFORMFIELD NAME="ORDER_ID"    PORTTYPE="INPUT/OUTPUT" DATATYPE="integer"  PRECISION="10" SCALE="0" EXPRESSION="ORDER_ID"                               DEFAULTVALUE=""/>
      <TRANSFORMFIELD NAME="CUSTOMER_ID" PORTTYPE="INPUT/OUTPUT" DATATYPE="nvarchar" PRECISION="50" SCALE="0" EXPRESSION="CUSTOMER_ID"                            DEFAULTVALUE=""/>
      <TRANSFORMFIELD NAME="COUNTRY_CODE" PORTTYPE="INPUT/OUTPUT" DATATYPE="nvarchar" PRECISION="5" SCALE="0" EXPRESSION="COUNTRY_CODE"                           DEFAULTVALUE=""/>
      <TRANSFORMFIELD NAME="OUT_REGION"  PORTTYPE="INPUT/OUTPUT" DATATYPE="nvarchar" PRECISION="20" SCALE="0" EXPRESSION="OUT_REGION"                             DEFAULTVALUE=""/>
      <TRANSFORMFIELD NAME="TAX_CODE"    PORTTYPE="OUTPUT"       DATATYPE="nvarchar" PRECISION="10" SCALE="0" EXPRESSION=":LKP.LKP_TAX_CODE(COUNTRY_CODE)"       DEFAULTVALUE=""/>
      <TRANSFORMFIELD NAME="LOAD_TS"     PORTTYPE="OUTPUT"       DATATYPE="datetime" PRECISION="23" SCALE="0" EXPRESSION="SYSDATE"                               DEFAULTVALUE=""/>
    </TRANSFORMATION>

    <!-- Connectors -->
    <CONNECTOR FROMFIELD="ORDER_ID"    FROMINSTANCE="SRC_ORDERS" FROMINSTANCETYPE="Source Definition" TOFIELD="ORDER_ID"    TOINSTANCE="SQ_ORDERS" TOINSTANCETYPE="Source Qualifier"/>
    <CONNECTOR FROMFIELD="CUSTOMER_ID" FROMINSTANCE="SRC_ORDERS" FROMINSTANCETYPE="Source Definition" TOFIELD="CUSTOMER_ID" TOINSTANCE="SQ_ORDERS" TOINSTANCETYPE="Source Qualifier"/>
    <CONNECTOR FROMFIELD="COUNTRY_CODE" FROMINSTANCE="SRC_ORDERS" FROMINSTANCETYPE="Source Definition" TOFIELD="COUNTRY_CODE" TOINSTANCE="SQ_ORDERS" TOINSTANCETYPE="Source Qualifier"/>

    <CONNECTOR FROMFIELD="ORDER_ID"    FROMINSTANCE="SQ_ORDERS" FROMINSTANCETYPE="Source Qualifier" TOFIELD="ORDER_ID"    TOINSTANCE="EXP_ENRICH" TOINSTANCETYPE="Expression"/>
    <CONNECTOR FROMFIELD="CUSTOMER_ID" FROMINSTANCE="SQ_ORDERS" FROMINSTANCETYPE="Source Qualifier" TOFIELD="CUSTOMER_ID" TOINSTANCE="EXP_ENRICH" TOINSTANCETYPE="Expression"/>
    <CONNECTOR FROMFIELD="COUNTRY_CODE" FROMINSTANCE="SQ_ORDERS" FROMINSTANCETYPE="Source Qualifier" TOFIELD="COUNTRY_CODE" TOINSTANCE="EXP_ENRICH" TOINSTANCETYPE="Expression"/>

    <!-- Connected lookup: EXP feeds CUSTOMER_ID into lookup input, gets OUT_REGION back -->
    <CONNECTOR FROMFIELD="CUSTOMER_ID" FROMINSTANCE="EXP_ENRICH"  FROMINSTANCETYPE="Expression"       TOFIELD="IN_CUST_ID"  TOINSTANCE="LKP_REGION" TOINSTANCETYPE="Lookup Procedure"/>
    <CONNECTOR FROMFIELD="OUT_REGION"  FROMINSTANCE="LKP_REGION"  FROMINSTANCETYPE="Lookup Procedure" TOFIELD="OUT_REGION"  TOINSTANCE="EXP_ENRICH" TOINSTANCETYPE="Expression"/>

    <CONNECTOR FROMFIELD="ORDER_ID"   FROMINSTANCE="EXP_ENRICH" FROMINSTANCETYPE="Expression" TOFIELD="ORDER_ID"  TOINSTANCE="TGT_ORDERS" TOINSTANCETYPE="Target Definition"/>
    <CONNECTOR FROMFIELD="OUT_REGION" FROMINSTANCE="EXP_ENRICH" FROMINSTANCETYPE="Expression" TOFIELD="REGION"    TOINSTANCE="TGT_ORDERS" TOINSTANCETYPE="Target Definition"/>
    <CONNECTOR FROMFIELD="TAX_CODE"   FROMINSTANCE="EXP_ENRICH" FROMINSTANCETYPE="Expression" TOFIELD="TAX_CODE"  TOINSTANCE="TGT_ORDERS" TOINSTANCETYPE="Target Definition"/>
    <CONNECTOR FROMFIELD="LOAD_TS"    FROMINSTANCE="EXP_ENRICH" FROMINSTANCETYPE="Expression" TOFIELD="LOAD_TS"   TOINSTANCE="TGT_ORDERS" TOINSTANCETYPE="Target Definition"/>

  </MAPPING>
</FOLDER>
</REPOSITORY>
</POWERMART>
